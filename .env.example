# PulseFlow — salin file ini ke .env lalu isi kredensialmu.
# .env TIDAK ikut ter-commit (lihat .gitignore).
BINANCE_API_KEY=isi_api_key_kamu
BINANCE_API_SECRET=isi_api_secret_kamu

# true  = order disimulasikan & dicatat ke paper_trades.json (aman, default)
# false = LIVE — order sungguhan ke Binance Futures (uang nyata!)
PAPER_MODE=true

# Risk per trade dalam % balance (dipakai untuk hitung position size)
RISK_PCT=1.0

# Leverage default untuk order futures
LEVERAGE=5

# Taker fee per sisi (% notional) — simulasi paper & estimasi ringkasan order
TAKER_FEE_PCT=0.05
